# BrewVote Server Configuration

# The port to bind the HTTP server to
PORT=5005

# The MongoDB connection URI (e.g. mongodb+srv://username:password@cluster.mongodb.net/dbname)
MONGODB_URI=mongodb://localhost:27017/brewvote

# Secret key used to sign JWTs (generate a long cryptographically secure random string)
JWT_SECRET=super_secret_jwt_key_change_in_production

# Node environment state (development, production, test)
NODE_ENV=development

# Bootstrap Administrator Email address
ADMIN_EMAIL=admin@brewvote.com
